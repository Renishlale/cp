#include <iostream>
using namespace std;

int main() {
    int arr[] = {16, 17, 4, 3, 5, 2};
    int n = 6;

    int max_from_right = arr[n-1];
    cout << "Leaders: " << max_from_right << " ";

    for(int i = n-2; i >= 0; i--) {
        if(arr[i] > max_from_right) {
            max_from_right = arr[i];
            cout << max_from_right << " ";
        }
    }

    return 0;
}
