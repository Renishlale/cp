#include <iostream>
using namespace std;

int main() {
    int arr[2][3] = {{1,2,3},{4,5,6}};
    int rows = 2, cols = 3;

    cout << "Transpose Matrix:\n";

    for(int i = 0; i < cols; i++) {
        for(int j = 0; j < rows; j++) {
            cout << arr[j][i] << " ";
        }
        cout << endl;
    }

    return 0;
}
