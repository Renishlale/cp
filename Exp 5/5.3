#include <iostream>
using namespace std;

const int SIZE = 10;
int table[SIZE];

int main() {
    int n, key;

    for (int i = 0; i < SIZE; i++)
        table[i] = -1;

    cout << "Enter number of distinct elements: ";
    cin >> n;

    for (int i = 0; i < n; i++) {
        cin >> key;
        int index = key % SIZE;
        table[index] = key;
    }

    for (int i = 0; i < SIZE; i++) {
        cout << i << ": ";
        if (table[i] != -1)
            cout << table[i];
        cout << endl;
    }
}
