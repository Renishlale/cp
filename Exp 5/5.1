#include <iostream>
using namespace std;

const int SIZE = 10;

struct Node {
    int data;
    Node* next;
};

Node* table[SIZE];

void insert(int key) {
    int index = key % SIZE;

    Node* newNode = new Node();
    newNode->data = key;
    newNode->next = table[index];
    table[index] = newNode;
}

void display() {
    for (int i = 0; i < SIZE; i++) {
        cout << i << ": ";
        Node* temp = table[i];
        while (temp != NULL) {
            cout << temp->data << " -> ";
            temp = temp->next;
        }
        cout << "NULL\n";
    }
}

int main() {
    int n, key;

    for(int i=0;i<SIZE;i++)
        table[i] = NULL;

    cout << "Enter number of elements: ";
    cin >> n;

    for (int i = 0; i < n; i++) {
        cin >> key;
        insert(key);
    }

    display();
}
