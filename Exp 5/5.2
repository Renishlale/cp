#include <iostream>
using namespace std;

const int SIZE = 10;
int table[SIZE];

void insert(int key) {
    int index = key % SIZE;

    while (table[index] != -1) {
        index = (index + 1) % SIZE;
    }

    table[index] = key;
}

void display() {
    for (int i = 0; i < SIZE; i++) {
        cout << i << ": ";
        if (table[i] != -1)
            cout << table[i];
        cout << endl;
    }
}

int main() {
    int n, key;

    for (int i = 0; i < SIZE; i++)
        table[i] = -1;

    cout << "Enter number of elements: ";
    cin >> n;

    for (int i = 0; i < n; i++) {
        cin >> key;
        insert(key);
    }

    display();
}
